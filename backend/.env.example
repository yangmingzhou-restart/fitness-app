# 阿里云百炼 DashScope API Key - 通义千问 Qwen-VL
# 获取地址: https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 分析引擎配置: qwen (默认), gemini, openai, ml (后续扩展)
ANALYSIS_ENGINE=qwen

# === 数据库 (二选一) ===
# 本地开发 (SQLite):
DATABASE_URL=sqlite:///./data/food_analyzer.db
# 阿里云部署 (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Basic Auth (客户端 API 调用凭证)
BASIC_AUTH_USER=test
BASIC_AUTH_PASS=ymzandcmftest

# 图片大小限制 (MB)
MAX_IMAGE_SIZE_MB=10

# === 部署到阿里云步骤 ===
# 1. cp .env.example .env 并填写真实的 DASHSCOPE_API_KEY
# 2. 切换 DATABASE_URL 为 PostgreSQL 连接串
# 3. docker compose up api-prod -d
