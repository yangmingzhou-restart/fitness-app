# 阿里云百炼 DashScope API Key - 通义千问 Qwen-VL
# 获取地址: https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 分析引擎配置: qwen (默认), gemini, openai, ml (后续扩展)
ANALYSIS_ENGINE=qwen

# 数据库路径 (SQLite)
DATABASE_URL=sqlite:///./data/food_analyzer.db

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# 图片大小限制 (MB)
MAX_IMAGE_SIZE_MB=10
